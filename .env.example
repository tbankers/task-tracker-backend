# Production environment
DOMAIN=team2.verstack.ru
ACME_EMAIL=your-email@example.com

# Traefik Dashboard auth (generate with: htpasswd -nB admin)
DASHBOARD_AUTH=admin:$$2y$$05$$...

# Backend image
GITHUB_REPO_BACKEND=tbankers/task-tracker-backend
IMAGE_TAG=latest

# Frontend image
GITHUB_REPO_FRONTEND=tbankers/task-tracker-frontend

# Database
DATABASE_URL=postgres://user:password@host:5432/tasktracker?sslmode=disable

# SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=your-email@gmail.com
