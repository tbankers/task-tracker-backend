# === База данных ===
# Строка подключения к PostgreSQL
DATABASE_URL=postgres://user:password@localhost:5432/tasktracker?sslmode=disable

# === Безопасность ===
# Секрет для подписи JWT токенов. Обязательно замени в проде!
# Минимум 32 символа, любая случайная строка
JWT_SECRET=change-me-to-something-random

# === Фронтенд ===
# URL фронтенда для ссылки сброса пароля
FRONTEND_URL=https://localhost

# === CORS ===
# РазрешённыйOrigin для CORS (фронтенд URL)
CORS_ORIGIN=https://localhost

# === SMTP ('email) ===
# Настройки почтового сервера для отправки писем (сброс пароля)
# Если не заданы — письма не отправляются, в логи пишется заглушка
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
# Адрес отправителя (по умолчанию = SMTP_USERNAME)
SMTP_FROM=

# === Docker (для prod compose) ===
# Имя репозитория в GHCR
GITHUB_REPO=tbankers/task-tracker-backend
# Тег образа: latest, SHA коммита, имя ветки
IMAGE_TAG=latest
# Порт приложения
APP_PORT=8080

# === SSL (для prod) ===
# Путь к SSL сертификату
SSL_CERT_PATH=/etc/letsencrypt/live/yourdomain.com/fullchain.pem
# Путь к SSL ключу
SSL_KEY_PATH=/etc/letsencrypt/live/yourdomain.com/privkey.pem
# Домен для SSL
DOMAIN=yourdomain.com
